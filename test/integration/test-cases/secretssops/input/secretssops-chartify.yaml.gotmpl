environments:
  direct:
    values:
      - default.values.yaml
    secrets:
      - tmp/env-1.secrets.sops.yaml
      - tmp/env-2.secrets.sops.yaml
---
helmDefaults:
  kubeContext: minikube

releases:
  # This release uses dependencies which triggers the chartify code path.
  # Chartify is also triggered by: jsonPatches, strategicMergePatches, transformers, forceNamespace,
  # or when the chart directory has no Chart.yaml.
  - name: raw-with-deps
    chart: ../../../../charts/raw
    version: 0.0.1
    dependencies:
      - chart: ../../../../charts/raw
        version: 0.0.1
        alias: raw-dep
    secrets:
      - secrets.yaml
    values:
      - templates:
        - |
          apiVersion: v1
          kind: Secret
          metadata:
            name: chartify-secret
          stringData:
            key_1: {{ .Environment.Values.key_1 }}
            key_2: {{ .Environment.Values.key_2 }}
            my_other_key: {{` {{ .Values.my_other_secret }} `}}
